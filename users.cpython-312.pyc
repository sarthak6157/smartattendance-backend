services:
  - type: web
    name: smart-attendance-api
    runtime: python
    buildCommand: pip install -r requirements.txt
    startCommand: uvicorn main:app --host 0.0.0.0 --port $PORT
    envVars:
      - key: DATABASE_URL
        sync: false
      - key: SECRET_KEY
        value: SmartAttendance2025TMU@SecretKey#Sarthak
      - key: FRONTEND_URL
        sync: false
